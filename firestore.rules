rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Individual collection rules
    
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || hasRole('admin');
      allow delete: if hasRole('admin');
    }

    match /announcements/{id} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    match /applications/{id} {
      allow create: if isSignedIn();
      allow read: if hasRole('admin') || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if hasRole('admin');
    }

    match /students/{id} {
      allow read: if isSignedIn() && (hasRole('admin') || hasRole('teacher') || (hasRole('student') && getUserData().studentId == id));
      allow write: if hasRole('admin');
    }

    match /classes/{id} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    match /subjects/{id} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    match /fees/{id} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    match /payments/{id} {
      allow read: if isSignedIn() && (hasRole('admin') || resource.data.studentId == request.auth.uid || (hasRole('student') && resource.data.studentId == getUserData().studentId));
      allow create: if isSignedIn();
      allow update: if hasRole('admin');
    }

    match /results/{id} {
      allow read: if isSignedIn() && (hasRole('admin') || hasRole('teacher') || (hasRole('student') && resource.data.studentId == getUserData().studentId));
      allow write: if hasRole('admin') || hasRole('teacher');
    }
  }
}
